# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# PostgreSQL (shared credentials for master + tenant databases)
# The DB user MUST have the CREATEDB privilege (database-per-tenant).
# ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=hospital
DB_PASSWORD=hospital_pass
# Default maintenance DB used only to CREATE the per-tenant databases
DB_BOOTSTRAP_NAME=postgres
# Central "master" database (tenants, auth users, refresh tokens)
MASTER_DB_NAME=hospital_master
# Per-tenant databases are named `${TENANT_DB_PREFIX}${slug}`
TENANT_DB_PREFIX=hospital_tenant_

# ─────────────────────────────────────────────────────────────
# JWT / Tokens
# ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-please-use-a-long-random-string
JWT_ACCESS_TTL=15m
# Long-lived opaque (crypto) refresh token lifetime, in days
REFRESH_TOKEN_TTL_DAYS=7

# ─────────────────────────────────────────────────────────────
# Google OAuth 2.0
# Create credentials at https://console.cloud.google.com/apis/credentials
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─────────────────────────────────────────────────────────────
# Email (account invitations / set-password links)
# Leave MAIL_HOST blank in development: emails (incl. the set-password
# link) are printed to the API console instead of being sent.
# ─────────────────────────────────────────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=Medisys <no-reply@medisys.local>
# How long a set-password invitation link stays valid, in hours
INVITE_TTL_HOURS=72

# ─────────────────────────────────────────────────────────────
# Seeding
# ─────────────────────────────────────────────────────────────
SEED_DEFAULT_PASSWORD=Password123!
